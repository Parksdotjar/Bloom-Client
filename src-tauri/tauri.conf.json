{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bloom Client",
  "version": "0.1.0",
  "identifier": "com.bloomunit.client",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bloom Client",
        "width": 1100,
        "height": 720,
        "decorations": false,
        "transparent": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Parksdotjar/Bloom-Client/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVDQzdDRDg5NTRCNDdCNEEKUldSS2U3UlVpYzNIWEpka2VWdTVYTW53UGQ4N2dSWnpkRUdDNXdTUzlrSG0weWVSTEZZcnlvcXkK"
    }
  }
}
